# Токен бота — получить у @BotFather командой /newbot
TELEGRAM_BOT_TOKEN=

# Имя бота без @ (используется как запасной return_url для онлайн-оплаты)
BOT_USERNAME=

# Ключ Anthropic API — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Какую модель Claude использовать для FAQ-консультанта. По умолчанию — Haiku 4.5
# (дешевле, для простых вопросов хватает с запасом). Для более развёрнутых ответов
# можно поставить claude-sonnet-4-6 (дороже примерно в 3 раза).
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Chat ID администратора — туда приходят уведомления о заказах, отзывах, кнопки смены статуса
ADMIN_CHAT_ID=

# (Опционально) URL Google Apps Script Web App для записи заказов в таблицу
SHEETS_WEBHOOK_URL=

# Порт HTTP-сервера (API корзины/стоп-листа). Render подставит сам через PORT.
PORT=3000

# --- Связь с Telegram: webhook (рекомендуется на Render) или polling (для локального запуска) ---
# На Render оставьте true — публичный адрес есть, webhook эффективнее, чем постоянный polling.
# При локальном запуске без публичного URL поставьте false, или просто не задавайте —
# без RENDER_EXTERNAL_URL бот сам откатится на polling.
USE_WEBHOOK=true
# Render подставляет это значение сам — руками вписывать не нужно (он узнаёт по
# наличию домена сервиса). Если деплоите не на Render — впишите свой публичный https-адрес.
RENDER_EXTERNAL_URL=
# Секрет для проверки, что запросы на /telegram-webhook реально от Telegram, а не подделка.
# На Render можно оставить пустым — render.yaml сам сгенерирует и закрепит значение.
# Для локального запуска/других хостингов — впишите любую длинную случайную строку.
WEBHOOK_SECRET=

# --- Дни выпечки для предзаказа ---
# Числа дней недели через запятую, 0=воскресенье..6=суббота. По умолчанию вт,чт,сб.
BAKE_WEEKDAYS=2,4,6

# --- Отзывы ---
REVIEW_DELAY_HOURS=4

# --- Онлайн-оплата (опционально) ---
# PAYMENT_PROVIDER выбирает, какой провайдер использует кнопка "Картой онлайн":
# yookassa (по умолчанию) или yoomoney. Можно заполнить оба блока переменных сразу —
# используется только тот провайдер, что указан здесь; переключение между уже
# настроенными провайдерами не требует правки кода, только смены этой переменной.
PAYMENT_PROVIDER=yookassa

# ЮKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ЮMoney (бывш. Яндекс.Деньги) — оплата на номер кошелька физлица, без shop_id.
# YOOMONEY_WALLET — номер вашего кошелька (например, 410011234567890).
# YOOMONEY_NOTIFICATION_SECRET — секрет для проверки подписи HTTP-уведомлений,
# задаётся один раз в настройках кошелька на yoomoney.ru → Настройки → Для разработчиков
# → HTTP-уведомления. Туда же нужно вписать адрес вашего бота вида
# https://ваш-бот.onrender.com/api/yoomoney-webhook — это делается в интерфейсе
# ЮMoney один раз вручную, переменной окружения для самого адреса не требуется.
YOOMONEY_WALLET=
YOOMONEY_NOTIFICATION_SECRET=

RETURN_URL=
